# OORTExA Configuration
# Define multiple targets and roles for transparent switching.

roles:
  orchestrator:
    model: "meta-llama/llama-3.1-70b-instruct"
    base_url: "http://localhost:8000/v1"
    api_key: "no-key-required"
  executor:
    model: "meta-llama/llama-3.1-70b-instruct"
    base_url: "http://localhost:8000/v1"
    api_key: ""
  analyst:
    model: "meta-llama/llama-3.1-70b-instruct"
    base_url: "http://localhost:8000/v1"
    api_key: "no-key-required"

# The active target used by abstract_tools.
# Can be overridden by CHAINGANG_TARGET environment variable.
active_target: "local"

targets:
  local:
    type: "local"

  container:
    type: "container"
    tool: "podman" # podman or docker
    image: "fedora:latest"
    name: "oortexa-worker"
    mode: "exec" # exec (existing container) or run (ephemeral)
    args: ["-i", "--rm"]

  ssh_remote:
    type: "ssh"
    ssh:
      host: "my-remote-box"
      user: "root"
      # identity: "~/.ssh/id_rsa"

  ssh_container:
    type: "ssh+container"
    ssh:
      host: "my-remote-box"
      user: "root"
    container:
      tool: "docker"
      image: "node:18"
      mode: "exec"
      name: "app-container"

  compose_dev:
    type: "compose"
    tool: "docker-compose" # docker-compose or podman-compose
    service: "api"
    file: "docker-compose.yml" # optional
    mode: "exec" # exec or run
